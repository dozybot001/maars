# LLM provider — pick whichever you have credits for.
# Default is Google Gemini 3 Flash Preview; switch providers via MAARS_CHAT_MODEL below.

# Google Gemini (default)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Anthropic Claude (optional)
# Get your key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Web search tool (Tavily) — used by Explorer in Step 4
# Get your key: https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# Optional overrides
# MAARS_CHAT_MODEL=google_genai:gemini-3-flash-preview   # default
# MAARS_CHAT_MODEL=anthropic:claude-sonnet-4-6           # alternative
# MAARS_REFINE_MAX_ROUND=5                               # default
