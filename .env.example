# MAARS Configuration
# Copy to .env and fill in your API key, then run: bash start.sh (use Git Bash on Windows)

# --- Google LLM ---
MAARS_GOOGLE_API_KEY=
MAARS_GOOGLE_MODEL=gemini-3-flash-preview
# Optional stage-specific overrides (fallback to MAARS_GOOGLE_MODEL when unset)
MAARS_REFINE_MODEL=
MAARS_RESEARCH_MODEL=
MAARS_WRITE_MODEL=gemini-3.1-pro-preview

# --- API ---
MAARS_API_CONCURRENCY=1
MAARS_OUTPUT_LANGUAGE=Chinese

# --- Research ---
MAARS_RESEARCH_MAX_ITERATIONS=3

# --- Team (Refine / Write multi-agent rounds) ---
MAARS_TEAM_MAX_DELEGATIONS=5

# --- Kaggle ---
MAARS_KAGGLE_API_TOKEN=
MAARS_DATASET_DIR=data/

# --- Docker Sandbox ---
MAARS_DOCKER_SANDBOX_IMAGE=maars-sandbox:latest
# Max seconds for a single code_execute (shell + user script). Default example: 35m.
MAARS_DOCKER_SANDBOX_TIMEOUT=2100
# Max seconds for one LLM turn (streaming + all tool calls). Default example: 70m (2× sandbox).
MAARS_AGENT_SESSION_TIMEOUT=4200
MAARS_DOCKER_SANDBOX_MEMORY=4g
MAARS_DOCKER_SANDBOX_CPU=1.0
MAARS_DOCKER_SANDBOX_NETWORK=true
MAARS_DOCKER_SANDBOX_GPU=false
