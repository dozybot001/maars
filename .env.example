# MAARS Configuration
# Copy this to .env and fill in your values

# Mode: mock, gemini, adk, or agno
MAARS_LLM_MODE=mock

# Google API Key (required for gemini, adk, and agno with google provider)
MAARS_GOOGLE_API_KEY=

# Model (shared across gemini, adk, and agno modes when provider is google)
MAARS_GEMINI_MODEL=gemini-2.5-flash

# Agno mode — for non-google providers
# MAARS_AGNO_MODEL_PROVIDER=google    # google, anthropic, or openai
# MAARS_AGNO_MODEL_ID=               # override for non-google (e.g. claude-sonnet-4-5)
# MAARS_OPENAI_API_KEY=
# MAARS_ANTHROPIC_API_KEY=
