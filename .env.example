# MAARS Configuration
# Copy to .env and fill in your API key, then run: bash start.sh (use Git Bash on Windows)
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │  Conservative preset — Apple M4 / 16 GB RAM / no discrete GPU      │
# │                                                                     │
# │  Rationale:                                                         │
# │  • 16 GB shared between macOS, Docker Desktop & sandbox container   │
# │  • M4 has 10 CPU cores — reserve headroom for host + browser        │
# │  • No NVIDIA GPU → GPU passthrough disabled                         │
# │  • Lower iteration / delegation counts to keep total runtime and    │
# │    API cost under control on a laptop                               │
# │  • All models use flash variants for speed; write stage upgrades    │
# │    to pro only because report quality matters most there            │
# └──────────────────────────────────────────────────────────────────────┘

# --- Google LLM ---
MAARS_GOOGLE_API_KEY=
MAARS_GOOGLE_MODEL=gemini-3-flash-preview
# Optional stage-specific overrides (fallback to MAARS_GOOGLE_MODEL when unset)
MAARS_REFINE_MODEL=                              # unset → uses flash (fast & cheap)
MAARS_RESEARCH_MODEL=                            # unset → uses flash (fast & cheap)
MAARS_WRITE_MODEL=gemini-3.1-pro-preview         # pro for final report quality

# --- API ---
MAARS_API_CONCURRENCY=1                          # 1 = sequential, safest for 16 GB
MAARS_API_REQUEST_INTERVAL=0                     # min seconds between LLM calls; set 1-2 for free-tier rate limits
MAARS_OUTPUT_LANGUAGE=Chinese

# --- Research ---
MAARS_RESEARCH_MAX_ITERATIONS=3                  # 3 rounds keep runtime ~15-25 min

# --- Team (Refine / Write multi-agent rounds) ---
MAARS_TEAM_MAX_DELEGATIONS=5                     # 5 rounds; raise to 8 on beefier machines

# --- Kaggle ---
MAARS_KAGGLE_API_TOKEN=
MAARS_DATASET_DIR=data/

# --- Docker Sandbox ---
MAARS_DOCKER_SANDBOX_IMAGE=maars-sandbox:latest
# Max seconds for a single code_execute (shell + user script).
MAARS_DOCKER_SANDBOX_TIMEOUT=2100                # 35 min — enough for mid-size training jobs
# Max seconds for one LLM turn (streaming + all tool calls).
MAARS_AGENT_SESSION_TIMEOUT=4200                 # 70 min (2× sandbox timeout)
MAARS_DOCKER_SANDBOX_MEMORY=4g                   # 4 GB of 16 GB total — leaves 12 GB for host
MAARS_DOCKER_SANDBOX_CPU=2.0                     # 2 of 10 cores — keeps host responsive
MAARS_DOCKER_SANDBOX_NETWORK=true                # needed for pip install inside sandbox
MAARS_DOCKER_SANDBOX_GPU=false                   # no NVIDIA GPU on this machine
