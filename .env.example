# MAARS Configuration
# Copy this to .env and fill in your values

# Mode: mock, gemini, adk, or agno
MAARS_LLM_MODE=mock

# Google API Key (required for gemini, adk, and agno with google provider)
MAARS_GOOGLE_API_KEY=

# Gemini model (used by gemini and adk modes)
MAARS_GEMINI_MODEL=gemini-2.0-flash

# Agno mode settings
# MAARS_AGNO_MODEL_PROVIDER=google    # google, anthropic, or openai
# MAARS_AGNO_MODEL_ID=gemini-2.5-flash
# MAARS_OPENAI_API_KEY=
# MAARS_ANTHROPIC_API_KEY=
