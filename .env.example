# MAARS Configuration
# Copy this file to .env and edit as needed.
# If you use `bash start.sh`, it will create .env from this template automatically when missing.
# All supported settings currently come from backend/config.py.

# -------------------------------------------------------------------
# Global model provider
# -------------------------------------------------------------------
# Choose one: google, anthropic, openai
MAARS_MODEL_PROVIDER=google

# Active provider only: fill the key for the provider you use.
# Stage-level overrides reuse the corresponding provider key below.

# Google
MAARS_GOOGLE_API_KEY=
MAARS_GOOGLE_MODEL=gemini-3-flash-preview

# Anthropic
MAARS_ANTHROPIC_API_KEY=
MAARS_ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# OpenAI
MAARS_OPENAI_API_KEY=
MAARS_OPENAI_MODEL=gpt-4o

# -------------------------------------------------------------------
# Optional per-stage model overrides
# -------------------------------------------------------------------
# Leave blank to fall back to the global provider/model above.
# Valid stage names: refine, research, write

MAARS_REFINE_PROVIDER=
MAARS_REFINE_MODEL=

MAARS_RESEARCH_PROVIDER=
MAARS_RESEARCH_MODEL=

MAARS_WRITE_PROVIDER=
MAARS_WRITE_MODEL=

# -------------------------------------------------------------------
# Research loop
# -------------------------------------------------------------------
# 1 = no evaluate/replan loop, 3 = up to 2 feedback rounds
MAARS_RESEARCH_MAX_ITERATIONS=3

# -------------------------------------------------------------------
# Kaggle
# -------------------------------------------------------------------
# Kaggle API token. Optional if you already use ~/.kaggle/kaggle.json.
MAARS_KAGGLE_API_TOKEN=

# Runtime-managed internal fields for Kaggle mode.
# Normally leave these blank; MAARS fills them during a Kaggle run.
MAARS_KAGGLE_COMPETITION_ID=
MAARS_DATASET_DIR=./datas

# -------------------------------------------------------------------
# Access token
# -------------------------------------------------------------------
# Recommended before exposing the service beyond localhost.
# If blank, /api/* is open without authentication.
MAARS_ACCESS_TOKEN=

# -------------------------------------------------------------------
# Docker sandbox
# -------------------------------------------------------------------
# Container image used by code_execute
MAARS_DOCKER_SANDBOX_IMAGE=maars-sandbox:latest

# Per-container timeout in seconds
MAARS_DOCKER_SANDBOX_TIMEOUT=600

# Docker memory limit, e.g. 4g, 8g, 512m
MAARS_DOCKER_SANDBOX_MEMORY=4g

# CPU quota expressed as virtual cores, e.g. 1.0, 2.0
MAARS_DOCKER_SANDBOX_CPU=1.0

# Allow network access from sandbox containers
MAARS_DOCKER_SANDBOX_NETWORK=true

# Max concurrent containers / parallel tasks
MAARS_DOCKER_SANDBOX_CONCURRENCY=2
