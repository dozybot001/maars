# MAARS Configuration
# Copy this to .env and fill in your values

# --- LLM Provider ---
# Choose one: "google", "anthropic", or "openai"
MAARS_MODEL_PROVIDER=google

# Google (fill if provider is google)
MAARS_GOOGLE_API_KEY=
MAARS_GOOGLE_MODEL=gemini-2.5-flash

# Anthropic (fill if provider is anthropic)
# MAARS_ANTHROPIC_API_KEY=
# MAARS_ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# OpenAI (fill if provider is openai)
# MAARS_OPENAI_API_KEY=
# MAARS_OPENAI_MODEL=gpt-4o

# --- Kaggle ---
# MAARS_KAGGLE_API_TOKEN=            # or use ~/.kaggle/kaggle.json

# --- Research ---
MAARS_RESEARCH_MAX_ITERATIONS=3      # 1 = no evaluate loop, 3 = up to 2 feedback rounds

# --- Docker Sandbox ---
MAARS_DOCKER_SANDBOX_IMAGE=maars-sandbox:latest
MAARS_DOCKER_SANDBOX_TIMEOUT=600
MAARS_DOCKER_SANDBOX_MEMORY=4g
MAARS_DOCKER_SANDBOX_CPU=1.0
MAARS_DOCKER_SANDBOX_NETWORK=true
MAARS_DOCKER_SANDBOX_CONCURRENCY=2    # max concurrent containers (and parallel tasks)
